# Claude Code local (personal) settings — never commit
.claude/settings.local.json
.claude/worktrees/
.worktrees/

# Scratch / reference clones — never commit
tmp/

# Build artifacts
build/
build-*/
build_*/
*.o
*.d
# ...but the systemd packaging dirs also end in ".d" — keep them tracked.
!packaging/sysusers.d/
!packaging/tmpfiles.d/

# Vendored HTTP/3 libcurl build (scripts/build-h3-curl.sh) — build output, like
# the xquic build dirs; never committed.
third_party/h3-curl/
# bench output at the repo root only — committed result snapshots live under
# docs/report/bench_results/, so scope this to the root dir (leading slash).
/bench_results/
demo_ticket_store.bin
demo_token_store.bin

# MITM test fixtures — regenerated at configure time by CMake (openssl), like the
# committed test.crt/origin.crt but never committed (they include private keys).
tests/certs/mitm-*
